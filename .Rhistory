sel_idx <- c(1, 3, 5)
all_rows <- list()
plot_order <- character()
for (i in sel_idx) {
load(paste0("tmp/outputDataAnalysis_", runs[i], ".RData"), verbose = FALSE)
min_unique_pep <- benchs[benchs$X == runs[i], "MinUniquePep"][1]
## Derive protein vectors from Stats (same logic you used)
all_prots <- sapply(Stats$Accession, function(x) unique(unlist(strsplit(x, ";"))))
all_prots <- unique(unlist(all_prots, use.names = FALSE))
reg_prots <- sapply(
Stats$Accession[Stats$`FDR_PolySTest 2 vs 1` < 0.05],
function(x) unique(unlist(strsplit(x, ";")))
)
reg_prots <- unique(unlist(reg_prots, use.names = FALSE))
## Log2 peptide counts (name matching guards against missing keys)
v_all <- log2(pep_per_prot[intersect(names(pep_per_prot), all_prots)])
v_reg <- log2(pep_per_prot[intersect(names(pep_per_prot), reg_prots)])
v_all <- v_all[is.finite(v_all) & !is.na(v_all)]
v_reg <- v_reg[is.finite(v_reg) & !is.na(v_reg)]
all_label <- paste0("Proteins with min. ", min_unique_pep,
" quantified peptides (n=", length(v_all), ")")
reg_label <- paste0("Proteins with min. ", min_unique_pep,
" quantified peptides (n=", length(v_reg), ")")
df_i <- rbind(
data.frame(run = paste0("Min peptides: ", min_unique_pep),
category = "All quantified proteins",
plot_label = all_label,
protein_count = length(v_all),
value = as.numeric(v_all),
stringsAsFactors = FALSE),
data.frame(run = paste0("Min peptides: ", min_unique_pep),
category = "Differentially regulated proteins (FDR < 0.05)",
plot_label = reg_label,
protein_count = length(v_reg),
value = as.numeric(v_reg),
stringsAsFactors = FALSE)
)
all_rows[[length(all_rows) + 1]] <- df_i
plot_order <- c(plot_order, all_label, reg_label)
}
